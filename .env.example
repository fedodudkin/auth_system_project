# --- Django Core Settings ---
# Секретный ключ Django. Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_django_secret_key_here
DEBUG=True # В продакшене должно быть False.
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database Settings (PostgreSQL) ---
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# --- JWT Settings ---
# Секретный ключ для подписи токенов (лучше сделать отличным от SECRET_KEY)
JWT_SECRET=your_jwt_private_key_here
JWT_EXPIRATION_HOURS=24 
